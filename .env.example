# ─────────────────────────────────────────────────────────
#  IBM watsonx.ai Credentials
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Your IBM Cloud API Key
WATSONX_API_KEY= 

# watsonx.ai endpoint (region-specific)
# US-South  : https://us-south.ml.cloud.ibm.com
# EU-DE     : https://eu-de.ml.cloud.ibm.com
# JP-TOK    : https://jp-tok.ml.cloud.ibm.com
# AU-SYD    : https://au-syd.ml.cloud.ibm.com
WATSONX_URL= 

# watsonx.ai Project ID (from your IBM Cloud project)
WATSONX_PROJECT_ID= 

# IBM Granite model to use
# Options: ibm/granite-3-8b-instruct | ibm/granite-3-2b-instruct | ibm/granite-13b-instruct-v2
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ─────────────────────────────────────────────────────────
#  Flask Application Settings
# ─────────────────────────────────────────────────────────

# Strong random secret key for session management
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_this_to_a_random_secret_key

# Set to True for development, False for production
FLASK_DEBUG=False

# Port to run the Flask app on
PORT=5000
